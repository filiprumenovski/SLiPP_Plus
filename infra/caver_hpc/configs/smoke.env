# smoke.env - config for infra/caver_hpc/slurm/run_v_tunnel_smoke.sbatch
# Format: KEY=VALUE (bash source-compatible)

# Required at submit/runtime:
# REPO_ROOT=/path/on/cluster/slipp_plus
# SIF_PATH=/path/on/cluster/slipp-caver.sif

SMOKE_N_STRUCTURES=4
WORKERS=4

SMOKE_INPUT_PARQUET=processed/v49/alphafold_holdout.parquet
SMOKE_SUBSET_PARQUET=processed/v_tunnel/smoke/alphafold_holdout_smoke.parquet
SMOKE_OUTPUT_PARQUET=processed/v_tunnel/smoke/alphafold_holdout_smoke_v_tunnel.parquet

STRUCTURES_ROOT=processed/v49/structures/alphafold_holdout
CAVER_JAR=tools/caver/caver.jar

ANALYSIS_OUTPUT_ROOT=processed/v_tunnel/smoke/caver_analysis
ANALYSIS_MANIFEST=processed/v_tunnel/smoke/caver_analysis_manifest.csv

MAX_MISSING_STRUCTURE_FRAC=0.05
MIN_CONTEXT_PRESENT_FRAC=0.95
MIN_PROFILE_PRESENT_FRAC=0.90
