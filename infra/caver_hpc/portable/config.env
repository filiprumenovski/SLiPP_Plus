# Portable HPC bundle config (source-compatible bash).
#
# This file is copied into the bundle and can be edited on HPC
# without touching scripts.

# Core runtime knobs
WORKERS=10
MAX_MISSING_STRUCTURE_FRAC=0.02
MIN_CONTEXT_PRESENT_FRAC=0.98
MIN_PROFILE_PRESENT_FRAC=0.95

# Java/CAVER
CAVER_JAR=tools/caver/caver.jar
JAVA_TOOL_OPTIONS=-Xms256m

# Training inputs/outputs (relative to bundle root)
BASE_PARQUET=processed/v_sterol/full_pockets.parquet
SOURCE_PDBS_ROOT=data/structures/source_pdbs
OUTPUT_PARQUET=processed/v_tunnel/full_pockets.parquet
CACHE_DIR=processed/v_tunnel/structure_json
REPORTS_DIR=reports/v_tunnel

# Optional 0-based batching. Leave empty for full run.
BATCH_INDEX=
BATCH_SIZE=

# Optional persisted analysis output
ANALYSIS_OUTPUT_ROOT=
ANALYSIS_MANIFEST=
